---
import Layout from '../layouts/Layout.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import Button from '../components/Button.astro';
import Icon from '../components/Icon.astro';
import HeroImage from '../components/HeroImage.astro';
import heroImage from '../assets/images/hero.png';
import Gallery from '../components/Gallery.astro';
---

<Layout>
	<main>
		<!-- Hero Section -->
		<section class="relative min-h-[80vh] flex items-center bg-ui-bg-light overflow-hidden">
			<!-- Decoration -->
			<div class="absolute top-0 right-0 w-1/2 h-full bg-brand-primary/5 -skew-x-12 translate-x-1/4"></div>
			
			<div class="container relative z-10 py-20">
				<div class="grid lg:grid-cols-2 gap-12 items-center">
					<div class="flex flex-col gap-8 max-w-2xl">
						<div class="flex flex-col gap-4">
							<span class="inline-flex items-center gap-2 text-brand-secondary font-bold tracking-[0.2em] uppercase text-sm">
								<span class="w-8 h-px bg-brand-secondary"></span>
								Estética K-Beauty en Madrid
							</span>
							<h1 class="text-5xl md:text-7xl font-black text-ui-text-main leading-[0.9] uppercase tracking-tighter">
								Con Hilo <br/>
								<span class="text-brand-secondary">Depilo</span>
							</h1>
							<p class="text-xl text-ui-text-muted leading-relaxed">
								Descubre la perfección de la técnica coreana. Especialistas en diseño de mirada, depilación con hilo y tratamientos faciales avanzados.
							</p>
						</div>
						
						<div class="flex flex-wrap gap-4">
							<Button size="lg" href="#servicios">
								Explorar Servicios
								<Icon name="ArrowRight" size={20} class="ml-2" />
							</Button>
							<Button variant="outline" size="lg">
								Reservar Cita
							</Button>
						</div>

						<div class="flex items-center gap-8 pt-4">
							<div class="flex flex-col">
								<span class="text-2xl font-black text-ui-text-main">4.9/5</span>
								<span class="text-xs text-ui-text-muted uppercase tracking-widest font-bold">Google Reviews</span>
							</div>
							<div class="w-px h-10 bg-brand-primary/20"></div>
							<div class="flex flex-col">
								<span class="text-2xl font-black text-ui-text-main">+2k</span>
								<span class="text-xs text-ui-text-muted uppercase tracking-widest font-bold">Clientes Felices</span>
							</div>
						</div>
					</div>

					<HeroImage variant="decorator" src={heroImage} alt="Imagen de hero" class="hidden lg:block" />
				</div>
			</div>
		</section>

		<!-- Services Section -->
		<ServicesGrid />

		<!-- Gallery Section -->
		<Gallery />

		<!-- Simple Footer -->
		<footer class="py-12 bg-ui-bg-dark text-white">
			<div class="container">
				<div class="flex flex-col md:flex-row justify-between items-center gap-8">
					<div class="flex flex-col gap-2">
						<span class="text-2xl font-black uppercase tracking-tighter">
							Con Hilo <span class="text-brand-primary">Depilo</span>
						</span>
						<p class="text-white/50 text-sm">
							© {new Date().getFullYear()} Con Hilo Depilo. Todos los derechos reservados.
						</p>
					</div>
					
					<div class="flex gap-6">
						<a href="#" class="text-white/70 hover:text-brand-primary transition-colors">
							<Icon name="Instagram" size={24} />
						</a>
						<a href="#" class="text-white/70 hover:text-brand-primary transition-colors">
							<Icon name="Facebook" size={24} />
						</a>
						<a href="#" class="text-white/70 hover:text-brand-primary transition-colors">
							<Icon name="MessageCircle" size={24} />
						</a>
					</div>
				</div>
			</div>
		</footer>
	</main>
</Layout>
