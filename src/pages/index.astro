---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/HeroSection.astro';
import ServicesGrid from '../components/ServicesGrid.astro';
import CoursesSection from '../components/CoursesSection.astro';
import Gallery from '../components/Gallery.astro';
import InfoCardSection from '../components/InfoCardSection.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
	<main>
		<!-- Hero Section -->
		<HeroSection />

		<!-- Services Section -->
		<ServicesGrid />

		<!-- Courses Section -->
		<CoursesSection />

		<!-- Gallery Section -->
		<Gallery />

		<!-- Info Section -->
		<InfoCardSection />

		<!-- New Footer Component -->
		<Footer />
	</main>
</Layout>
