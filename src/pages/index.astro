---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/organisms/HeroSection.astro';
import ServicesGrid from '../components/organisms/ServicesGrid.astro';
import CoursesSection from '../components/organisms/CoursesSection.astro';
import Gallery from '../components/organisms/Gallery.astro';
import InfoCardSection from '../components/organisms/InfoCardSection.astro';
import Footer from '../components/organisms/Footer.astro';
import SectionHeader from '../components/molecules/SectionHeader.astro';
---

<Layout>
	<main>
		<!-- Hero Section -->
		<HeroSection />

		<!-- Services Section -->
		<ServicesGrid>
			<SectionHeader slot="header" centered={true}>
				<Fragment slot="title">Nuestra Carta de Servicios</Fragment>
			</SectionHeader>
		</ServicesGrid>

		<!-- Courses Section -->
		<CoursesSection>
			<SectionHeader slot="header" centered={true}>
				<Fragment slot="title">Formación Exclusiva: Cursos Presenciales</Fragment>
			</SectionHeader>
		</CoursesSection>

		<!-- Gallery Section -->
		<Gallery>
			<SectionHeader slot="header" centered={true}>
				<Fragment slot="title">Resultados Reales</Fragment>
				<Fragment slot="subtitle">La sutileza es nuestra firma</Fragment>
			</SectionHeader>
		</Gallery>

		<!-- Info Section -->
		<InfoCardSection />

		<!-- New Footer Component -->
		<Footer />
	</main>
</Layout>
