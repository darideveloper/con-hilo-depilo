---
// HeroImage Component
import { Image } from "astro:assets";
import { cn } from "../utils/cn";
import type { HTMLAttributes } from "astro/types";
import Icon from "./Icon.astro";

interface Props extends HTMLAttributes<"div"> {
  variant?: "decorator" | "basic";
  href?: string;
  src?: ImageMetadata;
  alt: string;
  title?: string;
  class?: string;
}

const {
  src,
  alt,
  title,
  href,
  variant = "decorator",
  class: className,
  ...rest
} = Astro.props;

const variants = {
  decorator: "hero-decorator",
  basic: "hero-basic",
};

const Element = href ? "a" : "div";
---

<div
  class={cn(
    "relative",
    variant === "decorator" && "p-4 hero-decorator",
    variant === "basic" && "hero-basic",
    className,
  )}
  {...rest}
>
  {
    variant === "decorator" && (
      <>
        <div class="hero-bg-outer absolute inset-0 rounded-2xl bg-brand-primary/20" />
        <div class="hero-bg-inner absolute inset-4 rounded-2xl bg-brand-secondary/10" />
      </>
    )
  }

  <Element
    href={href}
    class="relative block aspect-[4/5] rounded-2xl overflow-hidden shadow-image"
  >
    {
      src ? (
        <Image
          src={src}
          alt={alt}
          loading="eager"
          decoding="async"
          class="w-full h-full object-cover block [backface-visibility:hidden] hero-img"
        />
      ) : (
        <div class="absolute inset-0 flex items-center justify-center text-brand-secondary/30">
          <Icon name="Image" size={64} />
        </div>
      )
    }

    {
      title && (
        <span class="absolute bottom-4 left-4 right-4 text-white font-extrabold text-caption uppercase tracking-[0.1em] [text-shadow:--shadow-title]">
          {title}
        </span>
      )
    }
  </Element>
</div>
