---
// HeroImage Component
import { Image } from "astro:assets";
import { cn } from "../utils/cn";
import type { HTMLAttributes } from "astro/types";
import Icon from "./Icon.astro";

interface Props extends HTMLAttributes<"div"> {
  variant?: "decorator" | "basic";
  href?: string;
  src?: ImageMetadata;
  alt: string;
  title?: string;
  class?: string;
}

const {
  src,
  alt,
  title,
  href,
  variant = "decorator",
  class: className,
  ...rest
} = Astro.props;

const variants = {
  decorator: "hero-decorator",
  basic: "hero-basic",
};

const Element = href ? "a" : "div";
---

<div class={cn("hero-wrap", variants[variant], className)} {...rest}>
  {variant === "decorator" && <div class="hero-bg-outer" />}
  {variant === "decorator" && <div class="hero-bg-inner" />}

  <Element href={href} class="hero-frame">
    {
      src ? (
        <Image
          src={src}
          alt={alt}
          loading="eager"
          decoding="async"
          class="hero-img"
        />
      ) : (
        <div class="hero-ph">
          <Icon name="Image" size={64} />
        </div>
      )
    }
    {title && <span class="hero-title">{title}</span>}
  </Element>
</div>

<style>
  .hero-wrap {
    position: relative;
  }

  .hero-frame {
    display: block;
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: 1rem;
    overflow: hidden;
  }

  .hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    backface-visibility: hidden;
  }

  .hero-title {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    right: 1rem;
    color: white;
    font-weight: 800;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-shadow: 0 1px 4px rgb(0 0 0 / 0.4);
  }

  .hero-ph {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: color-mix(in srgb, var(--color-brand-secondary) 30%, transparent);
  }

  .hero-decorator {
    padding: 1rem;
  }

  .hero-decorator .hero-frame {
    box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.25);
  }

  /* Background elements for decorator variant*/
  .hero-bg-outer {
    position: absolute;
    inset: 0;
    background-color: color-mix(
      in srgb,
      var(--color-brand-primary, #d4a853) 20%,
      transparent
    );
    border-radius: 1rem;
    rotate: -3deg;
    will-change: transform;
    backface-visibility: hidden;
    transition:
      rotate 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
      translate 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .hero-bg-inner {
    position: absolute;
    inset: 1rem;
    background-color: color-mix(
      in srgb,
      var(--color-brand-secondary) 10%,
      transparent
    );
    border-radius: 1rem;
    rotate: -3deg;
    will-change: transform;
    backface-visibility: hidden;
    transition:
      rotate 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
      translate 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .hero-decorator:hover .hero-bg-outer,
  .hero-decorator:hover .hero-bg-inner {
    rotate: 0deg;
    translate: 8px -8px;
  }

  /* Basic variant styling */
  .hero-basic .hero-frame {
    box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.25);
  }

  .hero-basic .hero-img {
    transition: scale 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
  }

  .hero-basic:hover .hero-img {
    scale: 1.06;
  }
</style>
