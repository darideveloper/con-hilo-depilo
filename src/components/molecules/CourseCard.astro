---
import { Image } from "astro:assets";
import Icon from "../atoms/Icon.astro";
import Button from "../atoms/Button.astro";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  duration: string;
  level: string;
  description?: string;
  image: ImageMetadata;
  alt: string;
}

const { title, duration, level, description, image, alt } = Astro.props;
---

<div
  class="group/card bg-white rounded-xl overflow-hidden shadow-sm hover:shadow-xl transition-all border border-brand-primary/10 flex flex-col"
>
  <div class="h-64 overflow-hidden relative">
    <Image
      src={image}
      alt={alt}
      class="w-full h-full object-cover group-hover/card:scale-105 transition-transform duration-500"
    />
    <div
      class="absolute top-4 right-4 bg-brand-primary text-white px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider"
    >
      Nivel: {level}
    </div>
  </div>
  <div class="p-6 space-y-4 flex flex-col flex-1">
    <h3 class="text-xl font-bold text-ui-text-main">{title}</h3>
    <div
      class="flex items-center gap-2 text-xs text-brand-secondary font-medium uppercase tracking-wide"
    >
      <Icon name="Calendar" size={16} />
      {duration}
    </div>
    <p class="text-sm text-ui-text-muted leading-relaxed flex-1">
      <slot>{description}</slot>
    </p>
    <Button variant="outline" class="w-full mt-auto text-xs uppercase" href="#">
      Más Información
    </Button>
  </div>
</div>
