---
import Badge from "../atoms/Badge.astro";
import Button from "../atoms/Button.astro";
import Icon from "../atoms/Icon.astro";
import { Image } from "astro:assets";
import { cn } from "../../utils/cn";

interface Props {
  title: string;
  price?: string;
  duration?: string;
  description?: string;
  image: ImageMetadata;
  category: string;
  class?: string;
  variant?: "primary" | "outline" | "ghost";
}

const {
  title,
  price,
  duration,
  description,
  image,
  category,
  class: className,
  variant = "outline",
} = Astro.props;
---

<article
  class={cn(
    "group flex flex-col bg-white border border-brand-primary/10 overflow-hidden transition-all rounded-2xl shadow-sm hover:shadow-lg hover:cursor-crosshair",
    className,
  )}
>
  <div class="relative overflow-hidden aspect-[4/3]">
    {
      price && (
        <Badge
          class="absolute top-4 right-4 z-20 bg-white border-brand-primary/50"
          variant="primary"
        >
          {price}
        </Badge>
      )
    }
    <Image
      src={image}
      alt={title}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
    />
  </div>

  <div class="flex flex-col flex-1 gap-3 p-6">
    <div class="flex flex-col gap-1">
      <h3 class="text-bold">
        {title}
      </h3>
      {
        duration && (
          <small class="flex items-center gap-1 text-ui-text-muted">
            <Icon name="Clock" size={14} />
            {duration}
          </small>
        )
      }
    </div>

    <p class="text-ui-text-muted flex-1">
      <slot>{description}</slot>
    </p>

    <Button variant={variant} size="sm" class="w-full mt-auto uppercase">
      Reservar ahora
    </Button>
  </div>
</article>
