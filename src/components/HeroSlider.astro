---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";
import Button from "./Button.astro";
import Badge from "./Badge.astro";

interface Slide {
  badge?: string;
  title: string;
  titleAccent?: string;
  description: string;
  primaryCta: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  image: ImageMetadata;
  imageAlt: string;
}

interface Props {
  slides: Slide[];
}

const { slides } = Astro.props;
const first = slides[0];
---

<section class="relative bg-ui-bg-light">
  <div class="container relative z-10 py-16 lg:py-20">
    <div
      class="grid min-h-[78vh] items-center gap-12 lg:grid-cols-[1.02fr_0.98fr] lg:gap-16"
    >
      <!-- Columna izquierda -->
      <div class="flex max-w-[34rem] flex-col justify-center">
        {
          first.badge && (
            <div class="mb-6">
              <Badge variant="primary" class="text-brand-primary/70">
                {first.badge}
              </Badge>
            </div>
          )
        }

        <h1
          class="text-ui-text-main text-[clamp(3.5rem,7vw,5.25rem)] font-black leading-[0.9] tracking-[-0.04em]"
        >
          {first.title}
          {
            first.titleAccent && (
              <>
                <br />
                <span class="font-black italic text-brand-primary">
                  {first.titleAccent}
                </span>
              </>
            )
          }
        </h1>

        <p
          class="mt-8 max-w-[31rem] text-[1.15rem] leading-[1.7] text-ui-text-muted"
        >
          {first.description}
        </p>

        <div class="mt-8 flex flex-wrap gap-4">
          <Button size="md" href={first.primaryCta.href}>
            {first.primaryCta.label}
          </Button>

          {
            first.secondaryCta && (
              <Button
                variant="outline"
                size="md"
                href={first.secondaryCta.href}
              >
                {first.secondaryCta.label}
              </Button>
            )
          }
        </div>
      </div>

      <!-- Columna derecha -->
      <div class="flex flex-col items-center lg:items-start">
        <div class="w-full max-w-[34rem]">
          <div class="relative p-4 hero-decorator">
            <div
              class="hero-bg-outer absolute inset-0 rounded-2xl bg-brand-primary/20"
            >
            </div>
            <div
              class="hero-bg-inner absolute inset-4 rounded-2xl bg-brand-secondary/10"
            >
            </div>

            <div
              class="swiper hero-swiper relative rounded-2xl overflow-hidden aspect-[4/5] shadow-image"
            >
              <div class="swiper-wrapper">
                {
                  slides.map((slide) => (
                    <div class="swiper-slide">
                      <Image
                        src={slide.image}
                        alt={slide.imageAlt}
                        loading="eager"
                        decoding="async"
                        class="w-full h-full object-cover block"
                      />
                    </div>
                  ))
                }
              </div>
            </div>
          </div>

          <div class="hero-pagination mt-5 flex justify-center gap-2"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @import "swiper/css";
</style>

<script>
  import Swiper from "swiper";
  import { Autoplay, Pagination } from "swiper/modules";

  new Swiper(".hero-swiper", {
    modules: [Autoplay, Pagination],
    loop: true,
    speed: 650,
    autoplay: {
      delay: 5000,
      disableOnInteraction: false,
    },
    pagination: {
      el: ".hero-pagination",
      clickable: true,
      renderBullet: (_, className) =>
        `<button class="${className} hero-slider-bullet" aria-label="Ir al slide"></button>`,
    },
  });
</script>
