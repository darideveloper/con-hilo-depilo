---
import Badge from "./Badge.astro";
import Button from "./Button.astro";
import Icon from "./Icon.astro";
import { Image } from "astro:assets";
import { cn } from "../utils/cn";

interface Props {
  title: string;
  price?: string;
  duration?: string;
  description: string;
  image: string;
  category: string;
  class?: string;
}

const { title, price, duration, description, image, category, class: className } = Astro.props;
---

<article 
  class={cn(
    "group flex flex-col bg-white border border-brand-primary/10 overflow-hidden transition-all rounded-2xl hover:shadow-xl hover:border-brand-primary/30",
    className
  )}
>
  <div class="relative overflow-hidden aspect-video">
    <div class="absolute inset-0 bg-brand-primary/5 group-hover:bg-transparent transition-colors z-10" />
    <Badge class="absolute top-4 left-4 z-20" variant="primary">
      {category}
    </Badge>
    <Image 
      src={image} 
      alt={title}
      inferSize={true}
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
    />
  </div>

  <div class="flex flex-col flex-1 gap-4 p-6">
    <div class="flex flex-col gap-1">
      <h3 class="text-xl font-black text-ui-text-main leading-tight uppercase tracking-tight">
        {title}
      </h3>
      <div class="flex items-center gap-4 text-sm text-ui-text-muted font-medium">
        {price && (
          <span class="flex items-center gap-1">
            <Icon name="Tag" size={14} class="text-brand-secondary" />
            {price}
          </span>
        )}
        {duration && (
          <span class="flex items-center gap-1">
            <Icon name="Clock" size={14} class="text-brand-secondary" />
            {duration}
          </span>
        )}
      </div>
    </div>

    <p class="text-ui-text-muted text-sm leading-relaxed flex-1">
      {description}
    </p>

    <Button variant="outline" size="sm" class="w-full mt-2 group/btn">
      Reservar ahora
      <Icon name="ChevronRight" size={16} class="ml-1 transition-transform group-hover/btn:translate-x-1" />
    </Button>
  </div>
</article>
